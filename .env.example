# Copy this file to .env and fill in your values.
# This file is loaded automatically by scripts/register-with-store.mjs (and any
# other Node script that calls its tiny inline .env parser). For lead-funnel
# scripts, see lead-funnel/.env.example for that subdirectory's separate env.

# WebFactory Store API token (required for Stage 10c — storefront registration).
# Same secret token used by the webfactory-store project at tomekgroup.com to
# authenticate intake POSTs. Set in Vercel production under team_4Hr5Lqd6pY5D7gmeXDVsDmYx.
#
# To populate (pick one):
#   - Paste the secret directly: edit this file.
#   - Pull from Vercel:
#       cd ~/webfactory-store
#       vercel env pull .env.local --environment=production --scope tomek-group
#       (then copy the WEBFACTORY_STORE_API_KEY line into ~/WebFactory/.env)
#
# If unset, Stage 10c soft-fails (logs to jobs/{domain}/feedback.md, prints a
# curl-equivalent for manual retry, exits 0 — pipeline does NOT fail).
WEBFACTORY_STORE_API_KEY=

# Optional override — point register-with-store.mjs at a non-production intake
# endpoint (e.g., for testing against a preview deployment of webfactory-store).
# Defaults to https://tomekgroup.com/wf/api/jobs/intake when unset.
# WEBFACTORY_STORE_INTAKE_URL=
