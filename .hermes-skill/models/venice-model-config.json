  "veniceNativeParameters": {
    "temperature": {
      "description": "Sampling temperature. Lower = more deterministic",
      "ranges": {
        "orchestrator": "0.2-0.4",
        "brief": "0.2-0.4",
        "specs": "0.2-0.4",
        "perPage": "0.1-0.3",
        "visualPass": "0.2-0.5",
        "worldClassAudit": "0.1-0.3",
        "fixLoop": "0.1-0.3",
        "multilingual": "0.3-0.5",
        "scaffold": "0.2-0.4",
        "report": "0.3-0.5"
      }
    },
    "reasoningEffort": {
      "description": "Controls thinking depth. Venice models support: none, low, medium, high",
      "mapping": {
        "none": "No explicit reasoning chain",
        "low": "Minimal reasoning, faster",
        "medium": "Balanced reasoning depth",
        "high": "Maximum reasoning depth"
      }
    },
    "topP": {
      "description": "Nucleus sampling parameter",
      "default": 0.95
    },
    "presencePenalty": {
      "description": "Penalty for repeating tokens",
      "default": 0
    },
    "frequencyPenalty": {
      "description": "Frequency penalty",
      "default": 0
    }
  },

  "fallbackPolicy": {
    "description": "If primary model fails or is unavailable, use fallback in order",
    "strategy": "static",
    "maxRetries": 2,
    "retryDelayMs": 1000
  },

  "futureAdaptive": {
    "description": "Runtime model selection based on content complexity (Phase 2)",
    "enabled": false,
    "triggers": {
      "highComplexity": { "pages": "> 10", "images": "> 50", "industry": "enterprise|healthcare|finance" },
      "mediumComplexity": { "pages": "5-10", "images": "20-50", "industry": "retail|services" },
      "lowComplexity": { "pages": "< 5", "images": "< 20", "industry": "personal|portfolio" }
    }
  }
}
