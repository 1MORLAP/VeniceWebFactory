{
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__Claude_Preview__*",
      "mcp__stitch__*",
      "mcp__mcp-registry__search_mcp_registry",
      "Bash(cp SKILL.md .claude/commands/webfactory.md)",
      "Bash(cp SKILL.md ~/.claude/commands/webfactory.md)"
    ]
  },
  "mcpServers": {
    "stitch": {
      "command": "npx",
      "args": [
        "@_davideast/stitch-mcp",
        "proxy"
      ],
      "env": {
        "STITCH_API_KEY": "***REMOVED-STITCH-KEY***"
      }
    }
  }
}
