{
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__Claude_Preview__*",
      "mcp__stitch__*"
    ]
  },
  "mcpServers": {
    "stitch": {
      "command": "npx",
      "args": ["@_davideast/stitch-mcp", "proxy"],
      "env": {
        "STITCH_API_KEY": "${STITCH_API_KEY}"
      }
    }
  }
}
