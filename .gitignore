# ─── Per-build artifacts (huge — 9GB+ of customer data) ──────────────
jobs/
logs/

# ─── Node + Astro ─────────────────────────────────────────────────────
node_modules/
dist/
.astro/

# ─── Vercel ───────────────────────────────────────────────────────────
.vercel/
.vercel

# ─── Logs / env / temp ────────────────────────────────────────────────
*.log
.env
.env.local
.env.*.local

# ─── Claude Code runtime ──────────────────────────────────────────────
.claude/launch.json
.claude/worktrees/
.claude/settings.local.json
# Harness-managed symlinks to externally-installed skills (stripe-projects,
# upgrade-stripe, agentmail, etc.). These are restored from skills-lock.json
# via Claude Code on a fresh machine, NOT from this repo.
.claude/skills/
.agents/

# ─── Stray QA / temp / scratch artifacts ──────────────────────────────
# Temp Playwright probes (convention: leading underscore + -tmp suffix
# anywhere in scripts/).
scripts/_*-tmp.*
# Leftover qa.cjs report-output dirs (named after the dev-server PORT, e.g.
# 4351/, 22724/, 47712/). Real QA output lives under jobs/{domain}/qa-*/,
# which is gitignored already. These ones at the repo root are workers'
# misfires — keep them out of git.
/[0-9][0-9][0-9][0-9]/
/[0-9][0-9][0-9][0-9][0-9]/

# ─── OS / editor noise ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─── Orphan-dir prevention (workers occasionally misuse args and ─────
# ─── create scaffold dirs at the repo root instead of in jobs/) ──────
# These are the dirs we found accumulating over time — added 2026-04-26
# to prevent them ever being committed if they reappear at the repo root:
/option-a/
/a/
/option-a-plus/
/option-b/
/option-c/
/http:/
/=

# ─── Reference inspirations: don't ship build artifacts ──────────────
templates/inspiration/*/node_modules/
templates/inspiration/*/dist/
templates/inspiration/*/.astro/
templates/scaffold/node_modules/
