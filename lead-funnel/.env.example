# Google Places API (New) — required for discover.js
# Get from: https://console.cloud.google.com → Credentials → Create API Key
# Restrict the key to "Places API (New)" only.
GOOGLE_PLACES_API_KEY=

# Anthropic API key — required for score.js (vision-LLM scoring)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — model used for scoring. Defaults to claude-haiku-4-5
# (matches the "$1-2 per 100-lead batch" cost target).
#
# Upgrade tradeoffs:
#   claude-haiku-4-5      ~$1-2 per 100-lead batch — fine for screenshot grading
#   claude-sonnet-4-6     ~$5 per 100-lead batch  — better edge cases
#   claude-opus-4-7       ~$15-20 per 100-lead batch — best accuracy, overkill here
SCORING_MODEL=claude-haiku-4-5
