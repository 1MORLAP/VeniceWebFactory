# Google Places API (New) — required for discover.js
# Get from: https://console.cloud.google.com → Credentials → Create API Key
# Restrict the key to "Places API (New)" only.
GOOGLE_PLACES_API_KEY=

# Venice.ai API key — required for score.js (vision-LLM scoring)
# Get from: https://venice.ai/settings/api
# Venice's API is OpenAI-compatible (https://api.venice.ai/api/v1).
VENICE_API_KEY=

# Optional — model used for scoring. Defaults to google-gemma-3-27b-it
# (~$0.17 per 100-lead batch — well under the "$1-2" target).
#
# Vision-capable Venice models, sorted by quality/cost:
#   google-gemma-3-27b-it      ~$0.17/batch — recommended default. Mature, balanced.
#   qwen3-5-9b                 ~$0.13/batch — cheapest. 9B params, may struggle on nuance.
#   gemma-4-uncensored         ~$0.22/batch — newer Gemma 4 MoE.
#   mistral-small-2603         ~$0.27/batch — Mistral's vision model.
#   openai-gpt-4o-mini-2024-07-18  ~$0.27/batch — proven for screenshot grading.
#   qwen3-vl-235b-a22b         ~$0.37/batch — dedicated 235B VL. Step up if Gemma struggles.
#   grok-41-fast               ~$0.32/batch — Grok 4.1 fast tier.
#   claude-sonnet-4-6          ~$5.22/batch — best subjective reasoning. 30x cost.
#   claude-opus-4-7            ~$8.70/batch — maximum quality. Overkill.
SCORING_MODEL=google-gemma-3-27b-it

# AgentMail API key — required for sending outreach emails (scripts/send-outreach.js).
# Get from: https://console.agentmail.to
# Sender address (planned): webfactory@agentmail.to
AGENTMAIL_API_KEY=
# AgentMail inbox id of webfactory@agentmail.to (set after the inbox is created)
AGENTMAIL_INBOX_ID=

# Outreach customization (optional — sensible defaults bake in)
OUTREACH_SENDER_NAME=Tomek
WEBFACTORY_HOMEPAGE=https://webfactory.com
MARKETPLACE_HOST=webfactory.market
UNSUBSCRIBE_BASE=https://webfactory.market/u

# AgentMail webhook handler (scripts/webhook-agentmail.js)
WEBHOOK_PORT=3030
WEBHOOK_PATH=/agentmail
# Optional shared secret — set in AgentMail console as the X-AgentMail-Signature
# header value, then set the same string here.
AGENTMAIL_WEBHOOK_SECRET=
