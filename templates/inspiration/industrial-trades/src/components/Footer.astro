---
/*
 * Industrial Footer — utility-poster aesthetic
 * --------------------------------------------
 * Dark navy background with hi-vis hatched stripe at top. Address/hours/phone
 * laid out like a service-station decal. Mono attribution "FILE · CUSTOMER ·
 * EST · LIC". Social links present per SOCIAL LINKS RULE — show only the
 * platforms in manifest.footer.social with full external href + aria-label.
 */

interface Social {
  platform: string;     // 'facebook' | 'instagram' | 'youtube' | etc.
  href: string;          // full external URL — never "#" — see SOCIAL LINKS RULE
}

interface Props {
  businessName?: string;
  phone?: string;
  email?: string;
  address?: string;
  hours?: string;
  socials?: Social[];
}

const {
  businessName = 'Industrial Trades Co.',
  phone = '(555) 555-0100',
  email = 'service@example.com',
  address = '123 Workshop Way, City, ST',
  hours = 'Mon–Fri 7:00–17:00 · Sat 8:00–14:00',
  socials = [],
} = Astro.props;

const phoneHref = `tel:${phone.replace(/[^\d+]/g, '')}`;
const emailHref = `mailto:${email}`;
---

<footer class="bg-[var(--color-navy-900)] text-[var(--color-bone-200)]">
  <div class="hatched-border-y"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

      {/* Brand block */}
      <div class="md:col-span-2 lg:col-span-2">
        <h3 class="text-2xl lg:text-3xl font-extrabold text-[var(--color-bone-50)] uppercase tracking-tight">
          {businessName}
        </h3>
        <p class="mt-3 text-[var(--color-bone-300)] max-w-md leading-relaxed">
          Show up. Do the work. Stand behind it. That's the job.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={phoneHref}
            class="inline-flex items-center gap-2 bg-[var(--color-hivis-500)] text-[var(--color-ink)] px-5 py-3 font-bold hover:bg-[var(--color-hivis-400)] transition-colors min-h-[44px]"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57a1 1 0 00-1.02.24l-2.2 2.2a15.07 15.07 0 01-6.59-6.58l2.2-2.21a.96.96 0 00.25-1A11.36 11.36 0 018.5 4a1 1 0 00-1-1H4a1 1 0 00-1 1c0 9.39 7.61 17 17 17a1 1 0 001-1v-3.5a1 1 0 00-1-1z"/></svg>
            <span>{phone}</span>
          </a>
          <a
            href={emailHref}
            class="inline-flex items-center gap-2 border border-[var(--color-bone-200)]/30 text-[var(--color-bone-100)] px-5 py-3 font-semibold hover:bg-white/5 transition-colors min-h-[44px]"
          >
            Email
          </a>
        </div>
      </div>

      {/* Hours / address block */}
      <div>
        <h4 class="label-mono-lg text-[var(--color-hivis-400)] mb-4">HOURS</h4>
        <p class="text-sm text-[var(--color-bone-200)] leading-relaxed">{hours}</p>
        <h4 class="label-mono-lg text-[var(--color-hivis-400)] mt-6 mb-4">ADDRESS</h4>
        <p class="text-sm text-[var(--color-bone-200)] leading-relaxed">{address}</p>
      </div>

      {/* Socials block — only render if there are real socials in the manifest.
          Per SOCIAL LINKS RULE, OMIT this section entirely if socials array is empty.
          NEVER ship href="#" placeholders. */}
      {socials.length > 0 && (
        <div>
          <h4 class="label-mono-lg text-[var(--color-hivis-400)] mb-4">FOLLOW</h4>
          <div class="flex flex-wrap gap-3">
            {socials.map(s => (
              <a
                href={s.href}
                aria-label={s.platform.charAt(0).toUpperCase() + s.platform.slice(1)}
                target="_blank"
                rel="noopener noreferrer"
                class="w-11 h-11 flex items-center justify-center bg-[var(--color-navy-700)] hover:bg-[var(--color-hivis-500)] hover:text-[var(--color-ink)] transition-colors text-[var(--color-bone-50)]"
              >
                {/* Single SVG path per platform — Hero icons. The aria-label
                    above is what qa-check uses to identify the platform; the
                    icon glyph is for humans. */}
                {s.platform === 'facebook' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.675 0h-21.35C.59 0 0 .593 0 1.325v21.351C0 23.407.59 24 1.325 24h11.495v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116c.73 0 1.323-.593 1.323-1.325V1.325C24 .593 23.407 0 22.675 0z"/></svg>
                )}
                {s.platform === 'instagram' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.07 1.645.07 4.849 0 3.205-.012 3.584-.07 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                )}
                {s.platform === 'youtube' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                )}
                {(s.platform === 'twitter' || s.platform === 'x') && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                )}
                {s.platform === 'linkedin' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                )}
                {s.platform === 'yelp' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.16 12.594l-1.886-.621c-1.318-.435-1.79.336-1.79.336s-1.485 1.97-2.302 3.045c-.41.526-.71 1.06-.45 1.477.262.418.918.41 1.49.346 1.247-.135 4.74-.747 5.156-.847.572-.137 1.039-.572 1.116-1.024.107-.65-.456-1.456-1.34-1.712zm-3.957-2.94l-3.13-2.207c-.477-.336-.834-.59-1.124-.49-.524.183-.466.95-.45 1.225 0 0 .083 4.41.083 4.875 0 .51.31.717.736.69 0 0 1.92-.146 3.22-.245.717-.054 1.276.052 1.5-.342.336-.6-.328-1.55-.835-3.506z"/></svg>
                )}
                {!['facebook','instagram','youtube','twitter','x','linkedin','yelp'].includes(s.platform) && (
                  <span class="label-mono">{s.platform.slice(0,2).toUpperCase()}</span>
                )}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    {/* Bottom rule — utility-poster footer attribution */}
    <div class="mt-12 pt-6 border-t border-[var(--color-navy-700)] flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="label-mono text-[var(--color-bone-300)]">
        FILE · {businessName} · LICENSED · INSURED · &copy; {new Date().getFullYear()}
      </p>
      <p class="label-mono text-[var(--color-bone-300)]">
        BUILT BY WEBFACTORY · ASTRO · TAILWIND
      </p>
    </div>
  </div>
</footer>
