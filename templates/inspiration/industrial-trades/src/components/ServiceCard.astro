---
/*
 * Industrial ServiceCard
 * ----------------------
 * Hard-edged, bracket-numbered, photo-led card. Each card has:
 *   - SVC index ("[01] / [02] / [03]") in mono — like a parts catalog row
 *   - Service photo full-bleed top
 *   - Bone surface body with display-font heading + Inter body
 *   - Bottom rule with hi-vis arrow CTA
 *
 * Anti-pattern: NOT rounded corners (use sharp 90° edges), NOT centered text,
 * NOT pastel backgrounds, NOT generic icon (real photos only — see IMAGE-TO-PAGE
 * MAPPING rule).
 */

interface Props {
  index: string;        // "01", "02", "03" — bracket-numbered like a parts catalog
  title: string;
  description: string;
  photoSrc: string;     // distinct image per card (IMAGE DIVERSITY rule)
  photoAlt?: string;
  href: string;
}

const { index, title, description, photoSrc, photoAlt = title, href } = Astro.props;
---

<a
  href={href}
  class="group block bg-[var(--color-bone-50)] border border-[var(--color-bone-300)] hover:border-[var(--color-navy-700)] transition-colors fade-up"
>
  {/* Photo header — full-bleed, no rounded corners, mono SVC index overlaid */}
  <div class="relative aspect-[4/3] overflow-hidden">
    <img
      src={photoSrc}
      alt={photoAlt}
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <div class="absolute top-3 left-3">
      <span class="bg-[var(--color-navy-900)] text-[var(--color-hivis-400)] px-2.5 py-1 label-mono">
        SVC {index}
      </span>
    </div>
  </div>

  {/* Body — display heading + body copy + bottom rule with arrow */}
  <div class="p-6 lg:p-7">
    <h3 class="text-xl lg:text-2xl font-extrabold tracking-tight text-[var(--color-navy-900)] leading-snug">
      {title}
    </h3>
    <p class="mt-3 text-[var(--color-ink-muted)] text-sm leading-relaxed">
      {description}
    </p>
    <div class="mt-5 pt-4 border-t border-[var(--color-bone-300)] flex items-center justify-between">
      <span class="label-mono text-[var(--color-navy-700)]">VIEW DETAILS</span>
      <svg
        class="w-4 h-4 text-[var(--color-navy-900)] transition-transform group-hover:translate-x-1"
        fill="none" stroke="currentColor" viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</a>
