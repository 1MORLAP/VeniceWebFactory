---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  variant?: 'default' | 'cards';
}

const { items, variant = 'default' } = Astro.props;
---

<div class="space-y-4">
  {items.map((item) => (
    <details class={`group ${variant === 'cards' ? 'bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow' : 'bg-gray-50 rounded-xl border border-gray-100'}`}>
      <summary class="flex items-center justify-between cursor-pointer p-6 font-semibold text-gray-900 text-[1.05rem] select-none">
        <span class="pr-4">{item.question}</span>
        <div class="w-8 h-8 rounded-full bg-primary-50 flex items-center justify-center shrink-0 group-open:bg-primary-100 transition-colors">
          <svg class="w-4 h-4 text-primary-500 group-open:rotate-180 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </summary>
      <div class="px-6 pb-6 text-gray-600 leading-relaxed">
        {item.answer}
      </div>
    </details>
  ))}
</div>
