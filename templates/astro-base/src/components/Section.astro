---
interface Props {
  heading?: string;
  subheading?: string;
  eyebrow?: string;
  background?: 'white' | 'gray' | 'primary' | 'dark' | 'gradient';
  align?: 'left' | 'center';
  narrow?: boolean;
  id?: string;
}

const { heading, subheading, eyebrow, background = 'white', align = 'left', narrow = false, id } = Astro.props;

const bgClasses: Record<string, string> = {
  white: 'bg-white',
  gray: 'bg-gray-50',
  primary: 'bg-primary-50',
  dark: 'bg-gray-900 text-white',
  gradient: 'bg-gradient-to-br from-primary-50 via-white to-accent-50',
};

const headingColor: Record<string, string> = {
  white: 'text-gray-900',
  gray: 'text-gray-900',
  primary: 'text-gray-900',
  dark: 'text-white',
  gradient: 'text-gray-900',
};

const subColor: Record<string, string> = {
  white: 'text-gray-600',
  gray: 'text-gray-600',
  primary: 'text-gray-600',
  dark: 'text-gray-300',
  gradient: 'text-gray-600',
};
---

<section class={`relative py-20 md:py-28 lg:py-32 overflow-hidden ${bgClasses[background]}`} id={id}>
  {/* Subtle decorative elements */}
  {background === 'gradient' && (
    <>
      <div class="absolute top-0 right-0 w-72 h-72 bg-primary-200/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3" />
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-accent-200/15 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3" />
    </>
  )}

  <div class={`relative ${narrow ? 'max-w-3xl' : 'max-w-7xl'} mx-auto px-4 sm:px-6 lg:px-8`}>
    {(heading || subheading || eyebrow) && (
      <div class={`mb-14 md:mb-16 ${align === 'center' ? 'text-center mx-auto' : ''} max-w-3xl ${align === 'center' ? 'mx-auto' : ''} fade-up`}>
        {eyebrow && (
          <p class={`text-sm font-bold tracking-widest uppercase mb-4 ${background === 'dark' ? 'text-accent-400' : 'text-primary-500'}`}>
            {eyebrow}
          </p>
        )}
        {heading && (
          <h2 class={`text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight ${headingColor[background]}`}>
            {heading}
          </h2>
        )}
        {subheading && (
          <p class={`mt-5 text-lg md:text-xl leading-relaxed ${subColor[background]}`}>
            {subheading}
          </p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
